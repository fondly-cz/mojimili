# Proměnné pro Portainer stack (Stacks → tvůj stack → Environment variables).
# Tenhle soubor se nikam nenasazuje – je to jen seznam toho, co v Portaineru
# vyplnit. compose.prod.yml z nich čerpá přes ${...}.

# --- Povinné ---
# Vygeneruj lokálně: `php artisan key:generate --show`
APP_KEY=base64:ZMENME_TENTO_KLIC

APP_NAME=MojiMili
DOMAIN_NAME=crm.fondly.cz

DB_DATABASE=mojimili
DB_USERNAME=mojimili
DB_PASSWORD=zmen_silne_heslo
DB_ROOT_PASSWORD=zmen_silne_root_heslo

# Externí Docker síť, ve které běží Traefik (zkontroluj: `docker network ls`).
NETWORK_NAME=traefik_traefik
# Traefik certResolver pro Let's Encrypt (název z konfigurace tvého Traefiku).
CERT_RESOLVER=le

# GitHub token (read-only PAT s přístupem k organizaci fondly-cz).
# composer.json závisí na privátním repu fondly-cz/ares-connector, bez tokenu
# build image spadne na 404. Díky multi-stage buildu token nezůstává v image.
GITHUB_TOKEN=ghp_zmen_tento_token

# --- První admin (vytvoří se při startu, jen pokud e-mail ještě neexistuje) ---
ADMIN_NAME=Fondly Admin
ADMIN_EMAIL=spoluprace@fondly.cz
ADMIN_PASSWORD=zmen_silne_heslo

# --- Volitelné ---
LOG_LEVEL=warning

# Naplní ceník služeb (ServiceSeeder) při prvním nasazení nad prázdnou DB.
SEED_SERVICES=true

# --- E-mail (SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=noreply@fondly.cz

# --- Přihlášení přes Google (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI se skládá automaticky: https://${DOMAIN_NAME}/auth/google/callback
